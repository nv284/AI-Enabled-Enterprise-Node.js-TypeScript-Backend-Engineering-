{
  "name": "bookstore-v6-ai-reviewed",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "arch:cycles": "madge --circular --extensions ts src",
    "arch:check":  "depcruise --config .dependency-cruiser.js src",
    "arch:graph":  "depcruise --config .dependency-cruiser.js --output-type mermaid src"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^4.19.0",
    "reflect-metadata": "^0.2.0",
    "tsyringe": "^4.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.0",
    "dependency-cruiser": "^16.0.0",
    "madge": "^7.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
