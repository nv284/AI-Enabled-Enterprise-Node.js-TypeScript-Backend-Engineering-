{
 "name": "basic-grpc-typescript",
 "version": "1.0.0",
 "scripts": {
  "proto": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./generated --grpc_out=grpc_js:./generated --plugin=protoc-gen-grpc=`npm bin`/grpc_tools_node_protoc_plugin -I ./proto ./proto/hello.proto",
  "build": "tsc",
  "server": "node dist/server.js",
  "client": "node dist/client.js"
 },
 "dependencies": {
  "@grpc/grpc-js": "^1.14.4",
  "@grpc/proto-loader": "^0.7.15"
 },
 "devDependencies": {
  "@types/node": "^26.1.0",
  "grpc_tools_node_protoc_ts": "^5.3.3",
  "grpc-tools": "^1.13.1",
  "ts-node": "^10.9.2",
  "typescript": "^5.9.3"
 }
}
