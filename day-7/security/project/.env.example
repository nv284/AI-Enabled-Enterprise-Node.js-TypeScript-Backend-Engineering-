# Copy to .env and fill in.
NODE_ENV=development
PORT=3000

# 32+ random bytes. Generate with: openssl rand -base64 32
JWT_SECRET=please-change-me-to-32-random-bytes-or-more
JWT_ISSUER=notes-api
JWT_AUDIENCE=notes-web

# 32+ random bytes; used to sign the session cookie for the OAuth flow.
SESSION_SECRET=please-change-me-to-32-random-bytes-or-more

# CORS: comma-separated allow-list of origins
CORS_ORIGINS=http://localhost:5173

# SQLite for the workshop; swap to Postgres in prod.
DATABASE_URL="file:./dev.db"

# Google OIDC (leave blank to disable Google sign-in until Module 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
