{
  "name": "secure-notes-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p .",
    "audit": "npm audit --omit=dev",
    "semgrep": "semgrep --config .semgrep --config p/typescript --config p/owasp-top-ten --config p/nodejsscan src",
