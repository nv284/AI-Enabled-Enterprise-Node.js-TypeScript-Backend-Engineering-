# Copy this file to `.env` only when you switch from the simulated LLM to a real provider.
# The simulated LLM (default) needs NO configuration.

# Which LLM backend to use: "simulated" (default) or "openai"
LLM_PROVIDER=simulated

# Server port
PORT=3000

# --- Only needed when LLM_PROVIDER=openai ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
