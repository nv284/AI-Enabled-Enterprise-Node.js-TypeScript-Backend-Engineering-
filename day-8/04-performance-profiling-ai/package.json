{
  "name": "04-performance-profiling-ai",
  "version": "1.0.0",
  "description": "Deliberately slow Express app + autocannon + clinic.js + AI analysis",
  "private": true,
  "scripts": {
    "dev": "ts-node src/slowServer.ts",
    "load:small": "autocannon -c 10 -d 10 http://localhost:3004/hot",
    "load:big":   "autocannon -c 50 -d 20 http://localhost:3004/hot",
    "clinic:doctor": "clinic doctor -- node -r ts-node/register src/slowServer.ts",
    "clinic:flame":  "clinic flame  -- node -r ts-node/register src/slowServer.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "autocannon": "^7.15.0",
    "clinic": "^13.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
